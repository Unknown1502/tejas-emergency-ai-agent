# ==========================================================================
# Tejas Backend — Environment Variables
# ==========================================================================
#
# Copy this file to .env in the backend/ directory:
#
#   cp .env.example .env          (Linux/macOS)
#   copy .env.example .env        (Windows)
#
# Then fill in your values. Never commit .env to version control.
# In production (Cloud Run), these are set via Terraform or deploy.sh.
# ==========================================================================

# ─── Application ──────────────────────────────────────────────────────────
APP_NAME=Tejas
ENVIRONMENT=development    # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ─── Google Cloud Platform ────────────────────────────────────────────────
# Required for Firestore, Cloud Storage, and Vertex AI in staging/production.
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ─── Gemini Live API ──────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash-live-001

# Get your API key from: https://aistudio.google.com/apikey
# Local development:  set GEMINI_API_KEY and USE_VERTEX_AI=false
# Cloud Run deployed: leave GEMINI_API_KEY blank; USE_VERTEX_AI=true
#                     uses the Cloud Run service account automatically.
GEMINI_API_KEY=your-gemini-api-key-from-aistudio
USE_VERTEX_AI=false

# ─── Gemini Audio ─────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=100
# Prebuilt voice for TTS responses.
# Options: Orus (deep/authoritative), Puck, Charon, Kore, Fenrir, Aoede
VOICE_NAME=Orus

# ─── Video ────────────────────────────────────────────────────────────────
VIDEO_FPS_MIN=2
VIDEO_FPS_MAX=5
VIDEO_FRAME_WIDTH=1280
VIDEO_FRAME_HEIGHT=720
VIDEO_FRAME_QUALITY=70    # JPEG quality 0-100; lower = smaller frames

# ─── Firestore ────────────────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)
FIRESTORE_INCIDENTS_COLLECTION=incidents
FIRESTORE_VICTIMS_COLLECTION=victims
FIRESTORE_DISPATCHES_COLLECTION=dispatches
FIRESTORE_HAZMAT_COLLECTION=hazmat_data
FIRESTORE_PROTOCOLS_COLLECTION=medical_protocols

# ─── Cloud Storage ────────────────────────────────────────────────────────
# Bucket for Imagen 3 scene map images. Created by Terraform or deploy.sh.
# Convention: {your-gcp-project-id}-tejas-captures
GCS_BUCKET_NAME=your-gcp-project-id-tejas-captures

# ─── Google Maps Platform ─────────────────────────────────────────────────
# Optional. Enables real-time hospital proximity search via Google Places API.
# Without this key, get_nearest_hospital() falls back to a curated demo list
# that still works correctly during demos.
# Get a key at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ─── Session Management ───────────────────────────────────────────────────
SESSION_TIMEOUT_SECONDS=1800       # 30 minutes per incident session
MAX_CONCURRENT_SESSIONS=50

# ─── Proactive Scene Scanning ─────────────────────────────────────────────
# How often (in seconds) the agent silently re-scans the video feed for new
# hazmat placards, victims, and fire spread — even without user input.
PROACTIVE_SCAN_INTERVAL_SECONDS=30

# ─── WebSocket ────────────────────────────────────────────────────────────
WS_PING_INTERVAL=20
WS_HEARTBEAT_INTERVAL=30
WS_MAX_MESSAGE_SIZE=1048576    # 1 MB

# ─── CORS ─────────────────────────────────────────────────────────────────
# Allowed frontend origins. Must be a JSON array string.
#
# Development (default — no change needed):
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
#
# Production — replace with your deployed frontend Cloud Run URL after
# running deploy.sh, then redeploy the backend with the updated value:
# ALLOWED_ORIGINS=["https://tejas-frontend-HASH-uc.a.run.app","http://localhost:5173"]
